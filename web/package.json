{
    "name": "@formata/stof",
    "version": "0.9.21",
    "type": "module",
    "main": "./dist/doc.js",
    "types": "./dist/doc.d.ts",
    "exports": {
        ".": {
            "types": "./dist/doc.d.ts",
            "default": "./dist/doc.js"
        },
        "./wasm": "./dist/pkg/stof_bg.wasm"
    },
    "sideEffects": false,
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc && cpy pkg dist/ --parents",
        "prepublishOnly": "npm run build",
        "clean": "rimraf dist"
    },
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/dev-formata-io/stof"
    },
    "homepage": "https://stof.dev",
    "devDependencies": {
        "cpy-cli": "^7.0.0",
        "rimraf": "^6.1.2",
        "typescript": "^5.3.3"
    },
    "keywords": [
        "stof",
        "data-runtime",
        "wasm",
        "webassembly",
        "rust",
        "typescript",
        "json",
        "yaml",
        "toml",
        "schema",
        "validation",
        "sandbox",
        "config-as-code",
        "serialization",
        "runtime",
        "ai-context",
        "distributed-systems"
    ]
}
